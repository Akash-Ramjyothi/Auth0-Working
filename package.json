{
  "name": "01-login",
  "version": "1.0.0",
  "description": "Secure and production-ready Auth0 SPA SDK sample application built with Express.js",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "prod": "NODE_ENV=production node ./bin/www",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "keywords": [
    "auth0",
    "express",
    "nodejs",
    "authentication",
    "spa",
    "security",
    "oauth",
    "openid-connect"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/01-login.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/01-login/issues"
  },
  "homepage": "https://github.com/your-username/01-login#readme",
  "devDependencies": {
    "eslint": "^9.26.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0"
  }
}
